# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
PUBLIC_URL=http://localhost:3000
# Public storefront URL — used for canonical URLs, sitemap.xml and robots.txt
PUBLIC_SITE_URL=http://localhost:3001
CORRELATION_ID_HEADER=x-correlation-id
LOG_LEVEL=info
# Express trust-proxy: 'false' (direct, unspoofable socket IP), 'true', a hop
# count (e.g. 1 behind one reverse proxy), or a CIDR. Set to match your topology.
TRUST_PROXY=false

# Initial admin bootstrap (used by `npm run seed`). In production these are the
# ONLY way an admin is created; demo listings/editor are skipped when NODE_ENV=production.
SEED_ADMIN_EMAIL=admin@autoflow.example
SEED_ADMIN_PASSWORD=

# Database (admin connection: runs migrations and seeds, owns schema)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=autoflow
DB_ADMIN_USER=autoflow_owner
DB_ADMIN_PASSWORD=owner_change_me

# Database (app connection: low-privilege runtime user)
DB_APP_USER=app_user
DB_APP_PASSWORD=app_change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=replace-with-32-bytes-of-entropy
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace-with-32-bytes-of-entropy
JWT_REFRESH_TTL=2592000

# Auth brute-force
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900
AUTH_LOGIN_RATE_PER_MIN=10

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=autoflow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/autoflow
S3_PRESIGNED_PUT_TTL=600

# Media
MEDIA_MAX_BYTES=20971520
MEDIA_ORPHAN_TTL_HOURS=24

# FX
FX_PROVIDER=static
FX_STATIC_USD_UAH=41.5
FX_STATIC_USD_EUR=0.92
FX_STATIC_EUR_UAH=45.0
FX_CACHE_TTL=3600

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AutoFlow <no-reply@flux-lab.dev>
LEAD_NOTIFY_TO=

# Rate limit
LEAD_RATE_PER_HOUR=5
PUBLIC_API_RATE_PER_MIN=120

# Views
VIEW_DEDUP_TTL_SECONDS=600
VIEW_FLUSH_INTERVAL_SECONDS=60
