# Caddy v2. Site addresses come from the compose environment:
#   SITE_ADDRESS  — `autoflow.example.com` (auto-HTTPS via Let's Encrypt)
#                   or `http://157.90.x.y` (plain HTTP when there is no domain)
#   MEDIA_ADDRESS — `media.autoflow.example.com` or `http://157.90.x.y:8081`
# A bare hostname turns TLS on automatically; an explicit http:// prefix or
# port keeps it plain HTTP — no other changes needed between the two modes.

{$SITE_ADDRESS} {
	encode zstd gzip

	# No-op over plain HTTP; hardens the HTTPS mode.
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# API → NestJS. The /api prefix is part of the backend routing (global
	# prefix), so the path is forwarded as-is.
	@api path /api/*
	handle @api {
		reverse_proxy app:3000
	}

	# SEO files come straight from the API (skips the Next rewrite, whose
	# destination is frozen at image build time).
	@seo path /robots.txt /sitemap.xml
	handle @seo {
		rewrite * /api{uri}
		reverse_proxy app:3000
	}

	# Everything else → Next.js (it proxies /robots.txt and /sitemap.xml to
	# the API itself via rewrites).
	handle {
		reverse_proxy frontend:3001
	}
}

# Object storage: public bucket reads + presigned uploads. The backend signs
# URLs against MEDIA_ADDRESS (S3_ENDPOINT), so the browser PUTs arrive here
# and are proxied to MinIO with the signature intact.
{$MEDIA_ADDRESS} {
	encode zstd gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# The bucket's anonymous "download" policy also grants ListBucket — a GET
	# on the bucket root would enumerate every object key. Object reads and
	# presigned operations target /{bucket}/{key}, so blocking the bare bucket
	# path breaks nothing.
	@bucketList {
		method GET
		path /{$S3_BUCKET} /{$S3_BUCKET}/
	}
	respond @bucketList 403

	reverse_proxy minio:9000
}
