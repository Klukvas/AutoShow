# Caddy v2 — automatic HTTPS via Let's Encrypt.
# DOMAIN / MEDIA_DOMAIN come from the compose environment.

{$DOMAIN} {
	encode zstd gzip

	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# API → NestJS. The /api prefix is part of the backend routing (global
	# prefix), so the path is forwarded as-is.
	@api path /api/*
	handle @api {
		reverse_proxy app:3000
	}

	# Everything else → Next.js (it proxies /robots.txt and /sitemap.xml to
	# the API itself via rewrites).
	handle {
		reverse_proxy frontend:3001
	}
}

# Object storage: public bucket reads + presigned uploads. The backend signs
# URLs against https://{$MEDIA_DOMAIN} (S3_ENDPOINT), so the browser PUTs
# arrive here and are proxied to MinIO with the signature intact.
{$MEDIA_DOMAIN} {
	encode zstd gzip
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"

	# The bucket's anonymous "download" policy also grants ListBucket — a GET
	# on the bucket root would enumerate every object key. Object reads and
	# presigned operations target /{bucket}/{key}, so blocking the bare bucket
	# path breaks nothing.
	@bucketList {
		method GET
		path /{$S3_BUCKET} /{$S3_BUCKET}/
	}
	respond @bucketList 403

	reverse_proxy minio:9000
}
