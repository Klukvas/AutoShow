# Production environment for the single-server deploy.
# Copy to /opt/autoflow/.env on the server and fill in the values.
# Generate secrets with: openssl rand -hex 32

# --- Deploy interpolation (used by docker-compose.yml itself) ---
DOCKERHUB_USER=your-dockerhub-username
# IMAGE_TAG is exported by the deploy workflow per release; leave unset here.
DOMAIN=autoflow.example.com
MEDIA_DOMAIN=media.autoflow.example.com

# --- Application ---
NODE_ENV=production
PORT=3000
API_PREFIX=api
PUBLIC_URL=https://autoflow.example.com
PUBLIC_SITE_URL=https://autoflow.example.com
CORS_ORIGINS=https://autoflow.example.com
# Behind Caddy: trust exactly one proxy hop so rate limiting sees real IPs.
TRUST_PROXY=1
LOG_LEVEL=info

# --- Database ---
DB_NAME=autoflow
DB_ADMIN_USER=autoflow_owner
DB_ADMIN_PASSWORD=CHANGE_ME_STRONG
DB_APP_USER=app_user
DB_APP_PASSWORD=CHANGE_ME_STRONG

# --- Redis ---
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT (openssl rand -hex 32) ---
JWT_ACCESS_SECRET=CHANGE_ME_32_BYTES_MIN
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=CHANGE_ME_32_BYTES_MIN
JWT_REFRESH_TTL=2592000

# --- Auth brute-force ---
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900
AUTH_LOGIN_RATE_PER_MIN=10

# --- S3 / MinIO ---
# Public endpoint: presigned PUTs from the admin browser must resolve here,
# and the signature host must match — hence the media domain, not "minio".
S3_ENDPOINT=https://media.autoflow.example.com
S3_REGION=us-east-1
S3_BUCKET=autoflow
S3_ACCESS_KEY=CHANGE_ME_NOT_MINIOADMIN
S3_SECRET_KEY=CHANGE_ME_NOT_MINIOADMIN
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=https://media.autoflow.example.com/autoflow
S3_PRESIGNED_PUT_TTL=600

# --- Media ---
MEDIA_MAX_BYTES=20971520
MEDIA_ORPHAN_TTL_HOURS=24

# --- FX ---
FX_PROVIDER=static
FX_STATIC_USD_UAH=41.5
FX_STATIC_USD_EUR=0.92
FX_STATIC_EUR_UAH=45.0
FX_CACHE_TTL=3600

# --- Email (leads notifications; leave empty to disable) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AutoFlow <no-reply@autoflow.example.com>
LEAD_NOTIFY_TO=

# --- Rate limits ---
LEAD_RATE_PER_HOUR=5
PUBLIC_API_RATE_PER_MIN=120

# --- Views ---
VIEW_DEDUP_TTL_SECONDS=600
VIEW_FLUSH_INTERVAL_SECONDS=60

# --- Seeds (first run: docker compose run --rm app npm run seed) ---
SEED_ADMIN_EMAIL=admin@autoflow.example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG

# --- Frontend (server-side runtime) ---
ADMIN_COOKIE_NAME=autoflow_admin
ADMIN_COOKIE_DOMAIN=
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SIGNING_KEY=CHANGE_ME_32_BYTES_MIN
