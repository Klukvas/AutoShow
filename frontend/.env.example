# Backend
BACKEND_INTERNAL_URL=http://localhost:3000/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000/api

# Public assets host (CDN/MinIO/S3) — comma-separated list for next/image allowlist
NEXT_PUBLIC_MEDIA_HOSTS=

# Auth (admin)
ADMIN_COOKIE_NAME=autoflow_admin
ADMIN_COOKIE_DOMAIN=
ADMIN_COOKIE_SECURE=false
# HMAC secret for signing the admin cookie payload. Generate with:
#   openssl rand -base64 48
# MUST be set in production; tampering rejects the cookie.
ADMIN_COOKIE_SIGNING_KEY=change-me-with-openssl-rand-base64-48

# Analytics / observability — placeholders
SENTRY_DSN=
